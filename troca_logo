<style>:root{--red:#DD222B;--red2:#E30613;--navy:#2D354C;--ink:#17171E;--bg:#0e1116;--card:#fff;--line:#e4e8ee;--muted:#5b6675;--shadow:0 14px 40px rgba(0,0,0,.28)}*{box-sizing:border-box}html,body{margin:0;padding:0}body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;background:var(--bg);color:var(--ink);height:100vh;overflow:hidden;display:flex;flex-direction:column}header.top{background:#fff;border-bottom:3px solid var(--red);display:flex;align-items:center;gap:12px;padding:10px 22px;flex:0 0 auto}header.top .logo{height:30px;width:auto;display:block}header.top .crm{color:var(--navy);font-weight:800;font-size:14px;letter-spacing:.5px;border-left:1px solid #d7dde6;padding-left:12px}header.top .tut{margin-left:auto;color:var(--navy);font-weight:700;font-size:14px;max-width:50%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.wrap{flex:1 1 auto;min-height:0;width:100%;padding:16px;display:flex}.stage{position:relative;flex:1 1 auto;background:var(--bg);border-radius:12px;overflow:hidden;display:flex;align-items:center;justify-content:center;min-height:0}.stage.cover{background:#fff}#shot{max-width:100%;max-height:100%;width:auto;height:auto;object-fit:contain;display:block;border-radius:6px}.stage.cover #shot{border-radius:0}.coverText{position:absolute;left:6.9%;top:81.5%;height:18.5%;right:4%;display:flex;align-items:center;color:#fff;font-weight:800;font-style:italic;letter-spacing:.2px;line-height:1.05;font-size:24px;text-shadow:0 1px 2px rgba(0,0,0,.35);overflow:hidden}.markers{position:absolute;left:0;top:0;width:0;height:0;pointer-events:none}.mk{position:absolute;border:3px solid var(--red);background:rgba(221,34,43,.10);pointer-events:auto;border-radius:9px;z-index:3}.mk.circle{border-radius:50%}.mk.click{cursor:pointer;pointer-events:auto}.mk .badge{position:absolute;top:-13px;left:-13px;width:26px;height:26px;border-radius:50%;background:var(--red);color:#fff;font-weight:800;font-size:13px;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 6px rgba(221,34,43,.5);border:2px solid #fff}.mk.circle .badge{top:50%;left:50%;transform:translate(-50%,-50%);box-shadow:none;border:0;background:transparent;color:var(--red);font-size:18px}@keyframes pulse{0%{box-shadow:0 0 0 0 rgba(221,34,43,.5)}70%{box-shadow:0 0 0 14px rgba(221,34,43,0)}100%{box-shadow:0 0 0 0 rgba(221,34,43,0)}}.mk{animation:pulse 1.8s ease-out infinite}.mk .clickhint{position:absolute;left:50%;bottom:-26px;transform:translateX(-50%);background:var(--navy);color:#fff;font-size:11px;font-weight:700;padding:3px 8px;border-radius:6px;white-space:nowrap;font-style:normal;animation:none}.mk.tip{border-color:var(--navy);background:rgba(45,53,76,.10);cursor:pointer;animation:none}.mk.tip.arrow{border:0;background:transparent}.mk.blur{border:0;background:transparent;-webkit-backdrop-filter:blur(9px);backdrop-filter:blur(9px);pointer-events:none;animation:none;z-index:2;border-radius:4px}.mk.tip .badge{background:var(--navy);box-shadow:0 2px 6px rgba(45,53,76,.5)}.mk.tip.circle .badge{top:-13px;left:-13px;transform:none;width:26px;height:26px;border-radius:50%;background:var(--navy);color:#fff;border:2px solid #fff;font-size:13px;box-shadow:0 2px 6px rgba(45,53,76,.5)}.tippop{position:absolute;width:240px;max-width:72%;background:#fff;border-radius:10px;box-shadow:var(--shadow);overflow:hidden;pointer-events:auto;z-index:6}.tiphd{background:var(--navy);color:#fff;font-weight:800;font-size:11px;letter-spacing:.5px;text-transform:uppercase;padding:6px 10px}.tiptx{padding:9px 11px;font-size:13px;color:var(--ink);line-height:1.45}.balloon{position:fixed;right:20px;bottom:20px;width:360px;max-width:calc(100vw - 40px);background:var(--card);border-radius:14px;box-shadow:var(--shadow);overflow:hidden;z-index:50}.bhead{display:flex;align-items:center;gap:8px;background:linear-gradient(100deg,var(--navy),#3b4763);color:#fff;padding:10px 14px}.btag{font-weight:800;font-size:13px;letter-spacing:.6px;text-transform:uppercase}.btag b{font-weight:800}.bfull{margin-left:auto;background:rgba(255,255,255,.18);color:#fff;border:0;border-radius:7px;width:30px;height:28px;font-size:15px;cursor:pointer;line-height:1}.bfull:hover{background:rgba(255,255,255,.30)}.bbody{padding:14px 16px 6px}.bkicker{display:inline-block;background:#f1f3f7;color:var(--navy);font-weight:800;font-size:11px;letter-spacing:.5px;text-transform:uppercase;border-radius:999px;padding:3px 10px;margin-bottom:8px}.bbody h3{margin:0 0 6px;font-size:17px;line-height:1.2;color:var(--ink)}.bbody p{margin:0;color:var(--muted);font-size:14px;line-height:1.5}.bnav{display:flex;align-items:center;gap:10px;padding:12px 16px 14px}.bbtn{border:1px solid var(--line);background:#fff;color:var(--navy);border-radius:9px;padding:9px 13px;font-weight:800;font-size:13px;cursor:pointer}.bbtn:hover{border-color:#c9d2dd}.bbtn.primary{margin-left:auto;border:0;background:var(--red);color:#fff}.bbtn.primary:hover{background:var(--red2)}.bbtn:disabled{opacity:.4;cursor:not-allowed}.bcount{font-weight:800;color:var(--navy);font-size:13px}.bdots{display:flex;flex-wrap:wrap;gap:6px;justify-content:center;padding:0 14px 14px}.bdots:empty{display:none}.dot{width:9px;height:9px;border-radius:50%;background:#cfd6df;cursor:pointer;border:0;padding:0;transition:transform .15s,background .15s}.dot.on{background:var(--red);transform:scale(1.3)}.dot.cap{background:var(--navy)}.dot.cap.on{background:var(--red)}body.fs-fallback{position:fixed;inset:0;z-index:9999}@media(max-width:760px){.wrap{padding:8px}.balloon{left:10px;right:10px;width:auto;bottom:10px}}</style>
