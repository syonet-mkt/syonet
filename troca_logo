<header class="top"><img class="logo" src="data:image/png;base64," alt="Syonet"><span class="tut">Next - Como trocar a logo do seu site?</span></header>
<div class="wrap">
<div class="stage" id="stage"><img id="shot" alt="Tela"><div class="markers" id="markers"><div class="coverText" id="coverText"></div></div></div>
</div>
<aside class="balloon" id="balloon"><div class="bhead"><span class="btag">Syonet <b>CRM</b></span><button class="bfull" id="fullBtn" type="button" title="Tela cheia">&#9974;</button></div><div class="bbody"><div class="bkicker" id="kicker"></div><h3 id="btitle"></h3><p id="btext"></p></div><div class="bnav"><button class="bbtn" id="prev" type="button">&larr; Voltar</button><span class="bcount" id="counter"></span><button class="bbtn primary" id="next" type="button">Proximo &rarr;</button></div><div class="bdots" id="dots"></div></aside>
<script id="DATA" type="application/json">{"nome":"Next - Como trocar a logo do seu site?","slides":[{"cover":true,"img":"data:image/png;base64,","title":"Next - Como trocar a logo do seu site?","intro":"","steps":[]},{"cover":false,"img":"data:image/png;base64,","title":"Gerenciamento de Sites","intro":"","steps":[{"n":1,"shape":"rect","x":79.09,"y":22.89,"w":4.84,"h":3.08,"text":"Clique em \"Editar\" para acessar as configurações do seu site.","goNext":true}],"tips":[],"blurs":[]},{"cover":false,"img":"data:image/png;base64,","title":"2 - Geral","intro":"","steps":[{"n":1,"shape":"rect","x":14.99,"y":66.68,"w":66.31,"h":10.16,"text":"Para efetuar a troca do logo do seu site, é necessário cadastrá-lo em uma das configurações de logo.\nImportante: sempre siga a resolução descrita na Next.","goNext":false}],"tips":[{"shape":"circle","x":19.62,"y":13.17,"w":5.41,"h":7.98,"text":"A configuração de logos fica localizada no item \"2 - Geral\"."}],"blurs":[]}]}</script>
<script>(function(){"use strict";
var D=JSON.parse(document.getElementById("DATA").textContent);
var SL=D.slides||[];
var P=[];
for(var si=0;si<SL.length;si++){var sd=SL[si];
 if(sd.cover){P.push({kind:"cover",img:sd.img,title:sd.title||""});continue;}
 var st=sd.steps||[];var tps=sd.tips||[];var bls=sd.blurs||[];
 if(st.length===0){P.push({kind:"plain",img:sd.img,title:sd.title||"",intro:sd.intro||"",tips:tps,blurs:bls});continue;}
 for(var k=0;k<st.length;k++){P.push({kind:"step",img:sd.img,title:sd.title||"",intro:sd.intro||"",step:st[k],k:k,kn:st.length,tips:tps,blurs:bls});}
}
var N=P.length;var i=0;
var elShot=document.getElementById("shot"),elMk=document.getElementById("markers"),elStage=document.getElementById("stage");
var elKicker=document.getElementById("kicker"),elTitle=document.getElementById("btitle"),elText=document.getElementById("btext"),elCounter=document.getElementById("counter"),elPrev=document.getElementById("prev"),elNext=document.getElementById("next"),elDots=document.getElementById("dots");
var elCoverText=document.getElementById("coverText");elCoverText.style.display="none";
var openPop=null;
function closeTip(){if(openPop&&openPop.parentNode){openPop.parentNode.removeChild(openPop);}openPop=null;}
function toggleTip(anchor,text){if(openPop&&openPop._a===anchor){closeTip();return;}closeTip();
 var pop=document.createElement("div");pop.className="tippop";pop._a=anchor;
 var hd=document.createElement("div");hd.className="tiphd";hd.textContent="Dica";
 var bx=document.createElement("div");bx.className="tiptx";bx.textContent=text||"(sem texto)";
 pop.appendChild(hd);pop.appendChild(bx);
 var lf=parseFloat(anchor.style.left)||0,tp2=parseFloat(anchor.style.top)||0,hh=parseFloat(anchor.style.height)||0;
 pop.style.left=lf+"%";pop.style.top=(tp2+hh)+"%";
 elMk.appendChild(pop);openPop=pop;
 var pr=pop.getBoundingClientRect(),mr=elMk.getBoundingClientRect();
 if(pr.right>mr.right-4){pop.style.left="auto";pop.style.right="2%";}
 if(pr.bottom>mr.bottom-4){pop.style.top=tp2+"%";pop.style.transform="translateY(-100%)";}
}
document.addEventListener("click",function(e){if(!openPop)return;var t=e.target;if(t&&t.closest&&(t.closest(".tippop")||t.closest(".mk.tip")))return;closeTip();});
document.addEventListener("keydown",function(e){if(e.key==="Escape")closeTip();});
function AS(c){return "<svg viewBox='0 0 100 100' style='width:100%;height:100%;display:block;overflow:visible;pointer-events:none'><line x1='86' y1='14' x2='37' y2='64' stroke='"+c+"' stroke-width='9' stroke-linecap='round'/><polygon points='22,80 29,56 45,72' fill='"+c+"'/></svg>";}
function syncOverlay(){var ir=elShot.getBoundingClientRect(),sr=elStage.getBoundingClientRect();if(!ir.width){return;}elMk.style.left=(ir.left-sr.left)+"px";elMk.style.top=(ir.top-sr.top)+"px";elMk.style.width=ir.width+"px";elMk.style.height=ir.height+"px";fitCover();}
function fitCover(){if(elCoverText.style.display==="none")return;var w=elShot.clientWidth||0;if(w>0)elCoverText.style.fontSize=Math.max(14,Math.round(w*0.030))+"px";}
window.addEventListener("resize",syncOverlay);elShot.addEventListener("load",syncOverlay);
function buildDots(){elDots.innerHTML="";if(N>22)return;for(var d=0;d<N;d++){(function(idx){var b=document.createElement("button");b.type="button";b.className="dot"+(P[idx].kind==="cover"?" cap":"");b.addEventListener("click",function(){go(idx);});elDots.appendChild(b);})(d);}}
buildDots();
function render(){closeTip();var p=P[i];elShot.src=p.img;var olds=elMk.querySelectorAll(".mk");for(var q=0;q<olds.length;q++){olds[q].parentNode.removeChild(olds[q]);}
 var bls=p.blurs||[];for(var bz=0;bz<bls.length;bz++){(function(bl){var bm=document.createElement("div");bm.className="mk blur";bm.style.left=bl.x+"%";bm.style.top=bl.y+"%";bm.style.width=bl.w+"%";bm.style.height=bl.h+"%";elMk.appendChild(bm);})(bls[bz]);}
 var isCover=(p.kind==="cover");
 elStage.classList.toggle("cover",isCover);
 elCoverText.style.display=isCover?"flex":"none";if(isCover){elCoverText.textContent=p.title||"";fitCover();}
 if(p.kind==="step"){var ac=p.step;
  var mk=document.createElement("div");mk.className="mk "+(ac.shape==="circle"?"circle":"rect")+(ac.goNext?" click":"");
  mk.style.left=ac.x+"%";mk.style.top=ac.y+"%";mk.style.width=ac.w+"%";mk.style.height=ac.h+"%";
  var bd=document.createElement("span");bd.className="badge";bd.textContent=ac.n;mk.appendChild(bd);
  if(ac.goNext){var hc=document.createElement("span");hc.className="clickhint";hc.textContent="Clique para continuar";mk.appendChild(hc);mk.addEventListener("click",function(){go(i+1);});}
  elMk.appendChild(mk);}
 var tips=p.tips||[];for(var tt=0;tt<tips.length;tt++){(function(tp){
   var shp=tp.shape;var cls=(shp==="arrow"?"arrow":(shp==="circle"?"circle":"rect"));
   var tm=document.createElement("div");tm.className="mk tip "+cls;
   tm.style.left=tp.x+"%";tm.style.top=tp.y+"%";tm.style.width=tp.w+"%";tm.style.height=tp.h+"%";
   if(shp==="arrow"){tm.innerHTML=AS("#2D354C");}var bd=document.createElement("span");bd.className="badge";bd.textContent="?";tm.appendChild(bd);
   tm.addEventListener("click",function(e){e.stopPropagation();toggleTip(tm,tp.text||"");});
   elMk.appendChild(tm);
 })(tips[tt]);}
 if(isCover){elKicker.style.display="none";elTitle.textContent="Vamos comecar";elText.textContent="Use os botoes abaixo ou as setas do teclado para navegar pelo treinamento.";}
 else if(p.kind==="plain"){elKicker.style.display=p.title?"inline-block":"none";elKicker.textContent="Etapa";elTitle.textContent=p.title||"";elText.textContent=p.intro||"";}
 else{elKicker.style.display="inline-block";elKicker.textContent="Passo "+(p.k+1)+" de "+p.kn;elTitle.textContent=p.title||("Passo "+(p.k+1));elText.textContent=p.step.text||"";}
 elCounter.textContent=(i+1)+" / "+N;
 elPrev.disabled=(i===0);
 if(isCover){elNext.textContent="Iniciar \u2192";}else{elNext.textContent=(i===N-1)?"Recomecar \u21bb":"Proximo \u2192";}
 var dots=elDots.querySelectorAll(".dot");for(var z=0;z<dots.length;z++){dots[z].classList.toggle("on",z===i);}
 syncOverlay();if(window.requestAnimationFrame)requestAnimationFrame(syncOverlay);
}
function go(idx){if(idx<0)idx=0;if(idx>N-1)idx=0;i=idx;render();}
elPrev.addEventListener("click",function(){go(i-1);});
elNext.addEventListener("click",function(){go(i+1);});
document.addEventListener("keydown",function(e){if(e.key==="ArrowRight")go(i+1);else if(e.key==="ArrowLeft"){if(i>0)go(i-1);}});
var fullBtn=document.getElementById("fullBtn");var docEl=document.documentElement;
function fsEl(){return document.fullscreenElement||document.webkitFullscreenElement||document.msFullscreenElement||null;}
function fsSup(){return !!(docEl.requestFullscreen||docEl.webkitRequestFullscreen||docEl.msRequestFullscreen);}
function reqFS(el){var fn=el.requestFullscreen||el.webkitRequestFullscreen||el.msRequestFullscreen;return fn?fn.call(el):null;}
function exitFS(){var fn=document.exitFullscreen||document.webkitExitFullscreen||document.msExitFullscreen;return fn?fn.call(document):null;}
function setLbl(on){fullBtn.title=on?"Sair da tela cheia":"Tela cheia";}
function fb(on){document.body.classList.toggle("fs-fallback",on);setLbl(on);}
fullBtn.addEventListener("click",function(){if(document.body.classList.contains("fs-fallback")){fb(false);return;}if(!fsSup()){fb(true);return;}try{if(!fsEl()){var pr=reqFS(docEl);if(pr&&pr.then)pr.catch(function(){fb(true);});}else{exitFS();}}catch(e){fb(true);}});
function onFs(){setLbl(!!fsEl());}document.addEventListener("fullscreenchange",onFs);document.addEventListener("webkitfullscreenchange",onFs);
document.addEventListener("keydown",function(e){if(e.key==="Escape"&&document.body.classList.contains("fs-fallback"))fb(false);});
render();
})();</script>
